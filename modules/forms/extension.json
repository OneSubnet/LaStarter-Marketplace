{
    "identifier": "forms",
    "name": "Forms",
    "type": "module",
    "version": "1.0.0",
    "description": "Create custom forms with live preview, collect responses, and analyze results — like Google Forms for your team",
    "author": "LaStarter",
    "license": "MIT",
    "homepage": "https://github.com/OneSubnet/lastarter-module-forms",
    "provider": "Modules\\Forms\\FormServiceProvider",
    "namespace": "Modules\\Forms",
    "lastarterVersion": ">=1.0.0",
    "keywords": ["forms", "surveys", "questionnaires", "responses", "data-collection"],
    "permissions": [
        "form.view",
        "form.create",
        "form.update",
        "form.delete",
        "form.publish",
        "form-submission.view",
        "form-submission.create",
        "form-submission.delete"
    ],
    "navigation": {
        "app": [
            {
                "title": "Forms",
                "icon": "FileText",
                "route": "forms.index",
                "permission": "form.view",
                "order": 25
            }
        ]
    },
    "settings": [
        {
            "key": "forms.max_file_upload",
            "label": "Max File Upload Size (MB)",
            "default": "10",
            "type": "number"
        },
        {
            "key": "forms.require_login",
            "label": "Require Login to Submit",
            "default": "false",
            "type": "select",
            "options": [
                { "label": "Yes", "value": "true" },
                { "label": "No", "value": "false" }
            ]
        },
        {
            "key": "forms.default_notification",
            "label": "Default Notification on Submission",
            "default": "none",
            "type": "select",
            "options": [
                { "label": "None", "value": "none" },
                { "label": "Email", "value": "email" },
                { "label": "In-App", "value": "in_app" }
            ]
        }
    ]
}
